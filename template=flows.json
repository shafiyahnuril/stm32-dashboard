  {
    "id": "fn_serial_parse",
    "type": "function",
    "z": "b446c83a074f9979",
    "name": "Parse UART CSV → JSON",
    "func": "// Format UART: \"mode,counter_value,adc_dma_val,led_mask_current\\r\\n\"\nvar line = (msg.payload || '').toString().trim();\nvar parts = line.split(',');\nif (parts.length < 4) return null;\n\nvar mode    = parseInt(parts[0]);\nvar counter = parseInt(parts[1]);\nvar adc     = parseInt(parts[2]);\nvar ledMask = parseInt(parts[3]);\n\nif (isNaN(mode) || isNaN(counter) || isNaN(adc) || isNaN(ledMask)) return null;\nif (mode < 1 || mode > 10) return null;\n\nmsg.payload = JSON.stringify({ mode: mode, counter: counter, adc: adc, ledMask: ledMask });\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 450,
    "y": 560,
    "wires": [["rate_limit_serial"]]
  },
