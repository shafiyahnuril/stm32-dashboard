  {
    "id": "fn_stm32_to_ws",
    "type": "function",
    "z": "b446c83a074f9979",
    "name": "STM32 SWD → JSON (debounced)",
    "func": "// Kumpulkan variabel ke flow context, broadcast SEKALI setelah semua variabel masuk (debounce 40ms)\nvar state = flow.get('stm32_state') || {\n  mode: 1, adc: 0, ledMask: 0, counter: 0,\n  score: 0, lives: 3, reactionMs: 0,\n  isrActive: false, isrRemainMs: 0\n};\n\nvar data = msg.payload;\nif (!data || !data.variablename || !data.variabledata || data.variabledata.length === 0) {\n  return null;\n}\n\nvar val = parseFloat(data.variabledata[data.variabledata.length - 1].y);\n\nswitch (data.variablename) {\n  case 'current_mode':    state.mode    = val; break;\n  case 'counter_value':   state.counter = val; break;\n  case 'adc_dma_val':     state.adc     = val; break;\n  case 'led_mask_current': state.ledMask = val; break;\n  case 'led_count':\n    // Fallback: konversi led_count (0-8) ke bitmask hanya jika led_mask_current belum tersedia\n    if (!flow.get('has_led_mask')) {\n      state.ledMask = val === 0 ? 0 : (0xFF00 >> Math.round(val)) & 0xFF;\n    }\n    break;\n}\n\nif (data.variablename === 'led_mask_current') flow.set('has_led_mask', true);\nflow.set('stm32_state', state);\n\n// Debounce: batalkan timer sebelumnya, kirim 40ms setelah update terakhir\nvar t = flow.get('debounce_timer');\nif (t) clearTimeout(t);\nflow.set('debounce_timer', setTimeout(function() {\n  var s = flow.get('stm32_state');\n  if (s) node.send({ payload: JSON.stringify(s) });\n}, 40));\n\nreturn null;",
    "outputs": 1,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 770,
    "y": 460,
    "wires": [["ws_out_stm32"]]
  },
