            "id": "66397fd3.d8111",
            "port": 0
          }
        ]
      }
    ],
    "env": [
      {
        "name": "varfilter",
        "type": "str",
        "value": "",
        "ui": {
          "icon": "font-awesome/fa-filter",
          "label": {
            "en-US": "Variable"
          },
          "type": "input",
          "opts": {
            "types": ["str"]
          }
        }
      }
    ],
    "color": "#3CB4E6"
  },
